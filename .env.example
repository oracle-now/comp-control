# ============================================================
# comp-control — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
TARGET_URL=https://app.ramp.com
TARGET_EMAIL=your-email@company.com
TARGET_PASSWORD=your-password

# --- Cloud mode (Browserbase) — optional ---
# Only needed if running with --mode cloud
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Agent behavior ---
# local | cloud
RUN_MODE=local
# true = never click buttons, just extract and report
DRY_RUN=false
# Port for the human-in-loop review dashboard
HUMAN_REVIEW_PORT=3001

# --- Flash mode ---
# true = use stripped-down system prompt (~60% fewer tokens per LLM call).
# Best for high-volume batch runs (50+ items) on a known, stable UI.
# IMPORTANT: Only enable after verifying the agent works correctly in
# full mode (COMP_CONTROL_FLASH_MODE=false) on the same target platform.
# Flash mode disables the structured flag-note output format and
# escalation narrative; escalation reports are unaffected.
# Default: false
COMP_CONTROL_FLASH_MODE=false

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info
