
  "name": "comp-control",
  "version": "0.1.0",
  "description": "AI-powered browser automation agent for compensation & expense control",
  "type": "module",
  "scripts": {
    "review": "tsx src/index.ts",
    "review:dry": "tsx src/index.ts --dry-run",
    "review:local": "tsx src/index.ts --mode local",
    "review:cloud": "tsx src/index.ts --mode cloud",
    "dashboard": "tsx src/ui/server.ts",
    "build": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@browserbasehq/stagehand": "^1.13.0",
