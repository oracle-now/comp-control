{
  "name": "comp-control",
  "version": "0.1.0",
  "description": "AI-powered browser automation agent for compensation & expense control",
  "type": "module",
  "scripts": {
    "review": "tsx src/index.ts",
    "review:dry": "tsx src/index.ts --dry-run",
    "review:local": "tsx src/index.ts --mode local",
    "review:cloud": "tsx src/index.ts --mode cloud",
    "dashboard": "tsx src/ui/server.ts",
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@browserbasehq/stagehand": "^2.0.0",
    "@browserbasehq/sdk": "^2.0.0",
    "@slack/web-api": "^7.0.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.1.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
